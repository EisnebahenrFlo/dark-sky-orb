{
  "rewrites": [
    { "source": "/((?!api/|assets/|src/|node_modules/|@vite/|@react-refresh|manifest.json|.*\\.(?:js|mjs|css|map|json|png|jpg|jpeg|webp|svg|ico|woff2?)).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/synoptik.ts": {
      "includeFiles": "api/_lib/**"
    },
    "api/weather.ts": {
      "includeFiles": "api/_lib/**",
      "memory": 256
    },
    "api/risk-warnings.ts": {
      "includeFiles": "api/_lib/**"
    },
    "api/rainbow-snapshot.ts": {
      "includeFiles": "api/_lib/**"
    },
    "api/rainbow-tile.ts": {
      "includeFiles": "api/_lib/**"
    }
  }
}
