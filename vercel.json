{
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/synoptik.ts": {
      "includeFiles": "api/_lib/**"
    },
    "api/weather.ts": {
      "includeFiles": "api/_lib/**",
      "memory": 256
    },
    "api/risk-warnings.ts": {
      "includeFiles": "api/_lib/**"
    },
    "api/rainbow-snapshot.ts": {
      "includeFiles": "api/_lib/**"
    },
    "api/rainbow-tile.ts": {
      "includeFiles": "api/_lib/**"
    }
  }
}
